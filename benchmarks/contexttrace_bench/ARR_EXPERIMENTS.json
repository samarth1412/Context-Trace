  "thesis": "ContextTrace formalizes evidence-chain forensics for localizing RAG and agent failures across claims, citations, evidence spans, source state, root causes, and regression tests.",
  "claim_policy": {
    "allowed": "ContextTrace is a benchmarked, local-first evidence-chain forensics system for claim-level RAG and agent failure diagnosis.",
    "blocked": "ContextTrace is the state-of-the-art RAG evaluation framework.",
    "broad_sota_requires_all_evidence_gates": true
  },
  "research_questions": [
    {
      "id": "RQ1",
      "question": "How accurately does ContextTrace detect claim-level RAG failures on externally sourced and public-document cases?",
      "hypothesis": "The full system improves failure macro-F1 and dangerous false-green rate over lexical and semantic-only profiles."
    },
    {
      "id": "RQ2",
      "question": "How accurately does ContextTrace localize evidence spans, citation failures, and primary root causes?",
      "hypothesis": "Explicit citation alignment, span localization, and diagnostic inference improve their matched output metrics without increasing dangerous false greens."
    },
    {
      "id": "RQ3",
      "question": "Which pipeline stages contribute to diagnostic quality, latency, and output coverage?",
      "hypothesis": "Cumulative ablations expose measurable quality gains and bounded latency costs for each diagnostic stage."
    },
    {
      "id": "RQ4",
      "question": "Are ContextTrace diagnoses correct and actionable to human reviewers?",
      "hypothesis": "Blinded reviewers prefer evidence-chain diagnoses over score-only outputs for identifying a concrete repair."
    }
  ],
  "datasets": [
    {
      "id": "ragtruth_primary",
      "role": "primary_external_calibration",
      "cases": 200,
      "review_status": "assisted_review_pending_independent"
